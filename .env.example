# Omit DATABASE_URL to keep using local SQLite during development.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Protects POST /api/maintenance/cleanup.
MAINTENANCE_SECRET=replace-with-a-long-random-secret

# Retention and opportunistic cleanup intervals.
ROOM_RETENTION_ACTIVE_HOURS=24
ROOM_RETENTION_FINISHED_HOURS=168
ROOM_CLEANUP_INTERVAL_MINUTES=15
