# Omit DATABASE_URL to keep using local SQLite during development.
DATABASE_URL=postgresql://user:password@host/database?sslmode=verify-full
POSTGRES_CONNECTION_TIMEOUT_MS=30000

# Optional local SQLite path when DATABASE_URL is omitted.
JOGASTOP_DATABASE_PATH=data/jogastop.db

# Protects POST /api/maintenance/cleanup.
MAINTENANCE_SECRET=replace-with-a-long-random-secret
# Protects the daily GET invoked automatically by Vercel Cron.
CRON_SECRET=replace-with-another-long-random-secret
# Protects /admin. Prefer a password you can type manually in the panel.
ADMIN_PASSWORD=H4vaiana$

# Retention and opportunistic cleanup intervals.
ROOM_RETENTION_ACTIVE_HOURS=24
ROOM_RETENTION_FINISHED_HOURS=168
ROOM_CLEANUP_INTERVAL_MINUTES=15
